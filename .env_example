# ═══════════════════════════════════════════════════════════════
# proxAI — Configuration
# Copier ce fichier :  cp .env_example .env
# ═══════════════════════════════════════════════════════════════

# ── Serveur proxy ──────────────────────────────────────────────
PROXY_HOST=0.0.0.0
PROXY_PORT=8080
LOG_LEVEL=info

# Multi-clients : workers (processus) + limite de requêtes simultanées
WORKERS=4
MAX_CONCURRENT_REQUESTS=200
HTTP_MAX_CONNECTIONS=500
HTTP_MAX_KEEPALIVE=100

# ── Sélection du modèle par défaut ─────────────────────────────
# Utilisé quand le client envoie model=default, model=auto, ou pas de modèle.
# Formats acceptés : llama3.2 | ollama/llama3.2 | openai/gpt-4o
DEFAULT_MODEL=ollama/llama3.2
DEFAULT_PROVIDER=ollama

# Providers à énumérer (vide = tous ceux avec clé API + ollama/vllm)
# ENABLED_PROVIDERS=ollama,vllm,groq,mistral,nvidia,openai

# Cache de l'énumération des modèles (secondes, 0 = pas de cache)
MODEL_CACHE_TTL=60

# ── Backends locaux ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
VLLM_BASE_URL=http://localhost:8000

# ── Providers cloud ──────────────────────────────────────────────
# Décommenter et remplir uniquement les providers que vous utilisez.

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Groq (fast inference — Llama, Mixtral, Gemma…)
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Together AI
TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Mistral AI (Mistral, Mixtral, Codestral…)
MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# NVIDIA NIM (cloud API or local NIM endpoint)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenRouter (agrégateur multi-modèles)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Azure OpenAI
AZURE_API_KEY=
AZURE_BASE_URL=
AZURE_API_VERSION=2024-02-15-preview

# Cohere
COHERE_API_KEY=
COHERE_BASE_URL=https://api.cohere.com/compatibility/v1

# Fireworks AI
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Perplexity
PERPLEXITY_API_KEY=
PERPLEXITY_BASE_URL=https://api.perplexity.ai

# xAI (Grok)
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1

# ── Routage explicite des modèles (optionnel) ──────────────────
# Associe un nom de modèle à un provider quand le préfixe n'est pas utilisé.
# Format JSON :
# MODEL_ROUTES={"gpt-4o":"openai","llama3.2":"ollama","claude-3-5-sonnet":"anthropic"}
# Format CSV :
# MODEL_ROUTES=gpt-4o:openai,llama3.2:ollama,claude-3-5-sonnet:anthropic
MODEL_ROUTES=